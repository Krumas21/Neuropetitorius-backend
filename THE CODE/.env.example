# Environment
ENV=production
LOG_LEVEL=INFO

# Database - UPDATE THESE WITH STRONG PASSWORDS IN PRODUCTION
DB_PASSWORD=your_strong_database_password_here
DATABASE_URL=postgresql+asyncpg://neuro:${DB_PASSWORD}@postgres:5432/neuro

# Redis
REDIS_URL=redis://redis:6379/0

# Security - GENERATE WITH: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_32_byte_secret_key_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_GENERATION_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Rate Limits
RATE_LIMIT_RPM=1000
RATE_LIMIT_MESSAGES_PM=60
RATE_LIMIT_CHAT_STUDENT_PM=30
RATE_LIMIT_INGEST_PM=10

# Admin API - GENERATE WITH: python -c "import secrets; print(secrets.token_hex(64))"
ADMIN_API_KEY=your_64_byte_admin_key_here

# Monitoring (optional)
SENTRY_DSN=

# Retrieval
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.65

# Gemini timeout (seconds)
GEMINI_TIMEOUT=45